<div class="language-python highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1"># UNQ_C1 (UNIQUE CELL IDENTIFIER, DO NOT EDIT)
</span><span class="k">def</span> <span class="nf">count_tweets</span><span class="p">(</span><span class="n">result</span><span class="p">,</span> <span class="n">tweets</span><span class="p">,</span> <span class="n">ys</span><span class="p">):</span>
    <span class="s">'''

            <span class="c1"># increment the number of correct by 1
</span>            <span class="n">num_correct</span> <span class="o">+=</span> <span class="mi">1</span>

    <span class="c1"># get the number of rows in the data dataframe (length of dataframe)
</span>    <span class="n">m</span> <span class="o">=</span> <span class="nb">len</span><span class="p">(</span><span class="n">data</span><span class="p">)</span>

    <span class="c1"># calculate the accuracy by dividing the number correct by m
</span>    <span class="n">accuracy</span> <span class="o">=</span> <span class="n">num_correct</span> <span class="o">/</span> <span class="n">m</span>

    <span class="c1">### END CODE HERE ###
</span>    <span class="k">return</span> <span class="n">accuracy</span>


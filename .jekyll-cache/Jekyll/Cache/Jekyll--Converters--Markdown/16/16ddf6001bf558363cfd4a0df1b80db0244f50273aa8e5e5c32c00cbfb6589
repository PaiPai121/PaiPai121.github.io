</span>        <span class="n">city1</span> <span class="o">=</span> <span class="n">row</span><span class="p">[</span><span class="s">"city1"</span><span class="p">]</span>

        <span class="c1"># get country1
</span>        <span class="n">country1</span> <span class="o">=</span> <span class="n">row</span><span class="p">[</span><span class="s">"country1"</span><span class="p">]</span>

        <span class="c1"># get city2
</span>        <span class="n">city2</span> <span class="o">=</span>  <span class="n">row</span><span class="p">[</span><span class="s">"city2"</span><span class="p">]</span>

        <span class="c1"># get country2
</span>        <span class="n">country2</span> <span class="o">=</span> <span class="n">row</span><span class="p">[</span><span class="s">"country2"</span><span class="p">]</span>

        <span class="c1"># use get_country to find the predicted country2
</span>        <span class="n">predicted_country2</span><span class="p">,</span> <span class="n">_</span> <span class="o">=</span> <span class="n">get_country</span><span class="p">(</span><span class="n">city1</span><span class="p">,</span> <span class="n">country1</span><span class="p">,</span> <span class="n">city2</span><span class="p">,</span> <span class="n">word_embeddings</span><span class="p">)</span>


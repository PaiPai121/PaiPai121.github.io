      <span class="s">f"is </span><span class="si">{</span><span class="n">hash_value_of_vector</span><span class="p">(</span><span class="n">vec</span><span class="p">,</span> <span class="n">planes</span><span class="p">)</span><span class="si">}</span><span class="s">"</span><span class="p">)</span>

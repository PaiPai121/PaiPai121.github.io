<span class="n">tmp_accuracy</span> <span class="o">=</span> <span class="n">S_Pre</span><span class="p">.</span><span class="n">test_logistic_regression</span><span class="p">(</span><span class="n">test_x</span><span class="p">,</span><span class="n">test_y</span><span class="p">)</span>

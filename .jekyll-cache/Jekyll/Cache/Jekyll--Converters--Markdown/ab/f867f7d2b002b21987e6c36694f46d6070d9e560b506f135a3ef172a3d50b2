        <span class="k">return</span> <span class="n">freqs</span>

    <span class="c1"># йЎҫеҗҚжҖқд№ү
</span>    <span class="k">def</span> <span class="nf">sigmoid</span><span class="p">(</span><span class="bp">self</span><span class="p">,</span><span class="n">z</span><span class="p">):</span>
        <span class="n">h</span> <span class="o">=</span> <span class="mi">1</span><span class="o">/</span><span class="p">(</span><span class="mi">1</span><span class="o">+</span><span class="n">np</span><span class="p">.</span><span class="n">exp</span><span class="p">(</span><span class="o">-</span><span class="n">z</span><span class="p">))</span><span class="c1">#жҢүз…§иЎЁиҫҫејҸ
</span>        <span class="k">return</span> <span class="n">h</span>
    
    <span class="c1">## жўҜеәҰдёӢйҷҚжі•жӣҙж–°theta
</span>    <span class="k">def</span> <span class="nf">gradientDescent</span><span class="p">(</span><span class="bp">self</span><span class="p">,</span><span class="n">x</span><span class="p">,</span><span class="n">y</span><span class="p">,</span><span class="n">theta</span><span class="p">,</span><span class="n">alpha</span><span class="p">,</span><span class="n">num_iters</span><span class="p">):</span><span class="c1"># alphaдёәеӯҰд№ зҺҮпјҢи¶Ҡе°ҸжҜҸж¬Ўж”№еҸҳзҡ„е°ұи¶Ҡе°Ҹ
